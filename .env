# Adresse de base de GLPI (sans slash final)
GLPI_BASE_URL=http://glpi.localhost

# URL de l'API v2 de GLPI
GLPI_API_URL=http://glpi.localhost/api.php/v2.3

# Client OAuth2 créé dans GLPI (onglet Configuration > OAuth)
# C'est le "identifier" de la table glpi_oauthclients, PAS le nom lisible
GLPI_CLIENT_ID=7f540689c280752e84db89dbf5cf42af418df5f79db79ddc721d029ae525f384
GLPI_CLIENT_SECRET=4cd6a6bb3e9666001c31ef236883de47010a2f1f8ce3b8796d488ccd21500bc1

# URI de redirection après login GLPI (doit être enregistrée dans le client OAuth)
# Pointe vers Express directement : l'échange code→token se fait immédiatement côté serveur
# sans délai de chargement React (évite "Authorization code has been revoked")
GLPI_REDIRECT_URI=http://localhost:3001/api/auth/callback

# Port du serveur Express
PORT=3001

# ── Backoffice : code unique remplaçant le login classique ────────────────────
# Le formulaire de saisie doit être PRÉ-REMPLI avec ce code (demande de l'énoncé),
# donc le frontend doit le connaître. C'est pourquoi il est dupliqué avec le
# préfixe VITE_ : Vite n'expose au navigateur QUE les variables préfixées VITE_
# (mécanisme de sécurité de Vite, pour éviter d'exposer des secrets par erreur).
# La variable sans préfixe (BACKOFFICE_CODE) reste utilisée côté serveur Express
# pour la vérification — c'est elle qui fait foi.
BACKOFFICE_CODE=GLPI-2026
VITE_BACKOFFICE_CODE=GLPI-2026
