# Adresse de base de GLPI (sans slash final)
GLPI_BASE_URL=http://glpi.localhost

# URL de l'API v2 de GLPI
GLPI_API_URL=http://glpi.localhost/api.php/v2.3

# Client OAuth2 créé dans GLPI (onglet Configuration > OAuth)
# C'est le "identifier" de la table glpi_oauthclients, PAS le nom lisible
GLPI_CLIENT_ID=7f540689c280752e84db89dbf5cf42af418df5f79db79ddc721d029ae525f384
GLPI_CLIENT_SECRET=4cd6a6bb3e9666001c31ef236883de47010a2f1f8ce3b8796d488ccd21500bc1

# URI de redirection après login GLPI (doit être enregistrée dans le client OAuth)
# Pointe vers Express directement : l'échange code→token se fait immédiatement côté serveur
# sans délai de chargement React (évite "Authorization code has been revoked")
GLPI_REDIRECT_URI=http://localhost:3001/api/auth/callback

# Port du serveur Express
PORT=3001

# ── Backoffice : code unique remplaçant le login classique ────────────────────
# Le formulaire de saisie doit être PRÉ-REMPLI avec ce code (demande de l'énoncé),
# donc le frontend doit le connaître. C'est pourquoi il est dupliqué avec le
# préfixe VITE_ : Vite n'expose au navigateur QUE les variables préfixées VITE_
# (mécanisme de sécurité de Vite, pour éviter d'exposer des secrets par erreur).
# La variable sans préfixe (BACKOFFICE_CODE) reste utilisée côté serveur Express
# pour la vérification — c'est elle qui fait foi.
BACKOFFICE_CODE=GLPI-2026
VITE_BACKOFFICE_CODE=GLPI-2026

# ── API GLPI v1 (legacy) : utilisée UNIQUEMENT pour l'upload d'images ─────────
# La v2 ne propose aucun endpoint d'upload de fichiers (vérifié sur les 2455
# endpoints de la doc Swagger) : seule la v1 supporte l'envoi multipart/form-data
# pour créer des Document (et les associer à un Computer/Monitor/...).
#
# Authentification v1 = 2 jetons distincts (différent de l'OAuth2 ci-dessus) :
#   - App-Token   : identifie l'application cliente (créé dans Configuration >
#                   Générale > onglet API > Clients API > "full access from localhost")
#   - user_token  : jeton personnel du compte utilisateur glpi (généré dans
#                   Mes paramètres > Clés d'accès distant)
# Avec ces deux jetons, on ouvre une session via GET /api.php/v1/initSession
# (header Authorization: user_token <user_token>) qui retourne un session_token
# à fournir ensuite dans le header Session-Token de chaque requête.
GLPI_API_V1_URL=http://glpi.localhost/api.php/v1
GLPI_APP_TOKEN=WdjUyaxwURbqDnI5P33iQZKLNzMGFZOHrrD4oiek
GLPI_USER_TOKEN=XRbNgXWjA2UEip7t3t07eWsGdXHvxBHJBdod46dB

# ── API GLPI v2 (compte de service) : repli pour les itemtypes absents de la v1 ──
# Certains itemtypes récents (ex. "Socket") ne sont PAS exposés par l'API v1
# (ERROR_RESOURCE_NOT_FOUND_NOR_COMMONDBTM) mais le SONT par la v2 (/Assets/<Type>).
# La v2 exige un access_token OAuth2 lié à un VRAI utilisateur (grant "password") —
# on réutilise le client OAuth2 ci-dessus (GLPI_CLIENT_ID/SECRET, grant "password"
# déjà autorisé) avec ce compte de service.
GLPI_SERVICE_USERNAME=glpi
GLPI_SERVICE_PASSWORD=glpi
